# Base URL of the backend API.
# In development the Vite dev server proxies /api to the backend, so the
# default relative value works out of the box.
# In production set this to your deployed API origin, e.g. https://api.example.com
VITE_API_URL=/api/v1

# Where the Vite dev server proxies /api. Must match the backend PORT.
# Defaults to http://localhost:5000 (the backend's default PORT). Override if
# your backend runs on a different port.
VITE_DEV_PROXY_TARGET=http://localhost:5000
