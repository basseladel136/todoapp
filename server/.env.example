# ─────────────────────────────────────────────────────────────
# Server configuration
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
# Port the API listens on. Change this if the default is already in use
# (e.g. another process is holding 8080). The server reads this value only.
PORT=5000

# Comma-separated list of allowed frontend origins (CORS).
CLIENT_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Supabase (Project Settings → API)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
# Service-role key — server-side ONLY, never expose to the browser.
